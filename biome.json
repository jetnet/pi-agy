{
	"files": { "includes": ["src/**", "*.json"] },
	"formatter": { "enabled": true, "indentStyle": "tab", "lineWidth": 120 },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"javascript": { "formatter": { "quoteStyle": "double" } }
}
